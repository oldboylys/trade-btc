# 复制此文件为 secrets.local.yaml，填入真实密钥（不入库）
exchanges:
  binance:
    api_key: "YOUR_BINANCE_API_KEY"
    api_secret: "YOUR_BINANCE_API_SECRET"
  hyperliquid:
    private_key: "YOUR_HYPERLIQUID_PRIVATE_KEY"   # EVM 私钥 (hex)
    wallet_address: "0x..."
  aster:
    api_key: "YOUR_ASTER_API_KEY"
    api_secret: "YOUR_ASTER_API_SECRET"
